#: templates/admin/partials/v4/pageview-stats.php:283
msgid "Optimized Assets"
msgstr "Optimizirani resursi"

#: templates/admin/preload.php:36
msgid "Start Preload"
msgstr "Pokreni prethodno učitavanje"

#: templates/admin/scan-fonts.php:25
msgid "Font Display"
msgstr "Prikaz fonta"

#: templates/admin/scan-fonts.php:25
msgid ""
"Controls how fonts render while loading. Swap shows text immediately using a"
" fallback font — recommended for PageSpeed."
msgstr ""
"Određuje kako se fontovi prikazuju tijekom učitavanja. Swap odmah prikazuje "
"tekst koristeći zamjenski font — preporučeno za PageSpeed."

#: templates/admin/scan-fonts.php:28
msgid "Text Font Display"
msgstr "Prikaz tekstualnog fonta"

#: templates/admin/scan-fonts.php:28
msgid ""
"How browsers handle text font loading. Swap shows fallback text immediately "
"— fixes the PageSpeed font-display warning. Icon fonts automatically use a "
"separate display setting to prevent garbled characters — configure in Icon "
"Fonts below."
msgstr ""
"Određuje kako preglednici obrađuju učitavanje tekstualnih fontova. Swap "
"odmah prikazuje zamjenski tekst — time se uklanja PageSpeed upozorenje za "
"font-display. Ikonski fontovi automatski koriste zasebnu postavku prikaza "
"kako bi se spriječili nečitki znakovi — konfigurirajte ih niže u odjeljku "
"Ikonski fontovi."

#: templates/admin/scan-fonts.php:29 templates/admin/scan-fonts.php:54
msgid "Swap"
msgstr "Swap"

#: templates/admin/scan-fonts.php:30 templates/admin/scan-fonts.php:79
msgid "Off"
msgstr "Isključeno"

#: templates/admin/scan-fonts.php:31 templates/admin/scan-fonts.php:55
msgid "Auto (Browser Default)"
msgstr "Auto (zadano u pregledniku)"

#: templates/admin/scan-fonts.php:32
msgid "Block (FOIT)"
msgstr "Block (FOIT)"

#: templates/admin/scan-fonts.php:33 templates/admin/scan-fonts.php:56
msgid "Fallback"
msgstr "Fallback"

#: templates/admin/scan-fonts.php:34 templates/admin/scan-fonts.php:57
msgid "Optional"
msgstr "Opcionalno"

#: templates/admin/scan-fonts.php:38
msgid "Preload Critical Fonts"
msgstr "Prethodno učitaj kritične fontove"

#: templates/admin/scan-fonts.php:39
msgid ""
"Preload above-the-fold fonts for faster first paint. Limited to 4 to avoid "
"bloat. Requires Critical CSS."
msgstr ""
"Prethodno učitajte fontove iznad pregiba za brži prvi prikaz. Ograničeno na "
"4 kako bi se izbjeglo nepotrebno povećanje. Zahtijeva Critical CSS."

#: templates/admin/scan-fonts.php:48
msgid "Icon Fonts"
msgstr "Ikonski fontovi"

#: templates/admin/scan-fonts.php:48
msgid ""
"Optimize loading of icon font libraries like Font Awesome, Material Icons, "
"and other icon sets."
msgstr ""
"Optimizirajte učitavanje biblioteka ikonskih fontova poput Font Awesomea, "
"Material Icons i drugih skupova ikona."

#: templates/admin/scan-fonts.php:52
msgid "Icon Font Display"
msgstr "Prikaz ikonskog fonta"

#: templates/admin/scan-fonts.php:52
msgid ""
"How browsers handle icon font loading. Block (recommended) keeps icons "
"invisible until loaded — prevents garbled characters that appear with swap. "
"Override this if you prefer a different strategy."
msgstr ""
"Određuje kako preglednici obrađuju učitavanje ikonskih fontova. Block "
"(preporučeno) drži ikone nevidljivima dok se ne učitaju — time se "
"sprječavaju nečitki znakovi koji se mogu pojaviti sa swap opcijom. "
"Promijenite ovo ako želite drugačiju strategiju."

#: templates/admin/scan-fonts.php:53
msgid "Block"
msgstr "Block"

#: templates/admin/scan-fonts.php:64
msgid "Lazy Load Icon Fonts"
msgstr "Lijeno učitavanje ikonskih fontova"

#: templates/admin/scan-fonts.php:64
msgid ""
"Load icon font stylesheets asynchronously to prevent render-blocking. Icons "
"appear after a brief invisible flash instead of blocking page paint."
msgstr ""
"Učitajte stilske datoteke ikonskih fontova asinkrono kako biste spriječili "
"blokiranje prikaza. Ikone se pojavljuju nakon kratkog nevidljivog treptaja "
"umjesto da blokiraju iscrtavanje stranice."

#: templates/admin/scan-fonts.php:66
msgid "Remove Duplicate Icon Fonts"
msgstr "Ukloni duplicirane ikonske fontove"

#: templates/admin/scan-fonts.php:66
msgid ""
"Detect and remove duplicate Font Awesome stylesheets when multiple versions "
"are loaded by different plugins."
msgstr ""
"Otkriva i uklanja duplicirane Font Awesome stilske datoteke kada različiti "
"dodaci učitavaju više verzija."

#: templates/admin/scan-fonts.php:74
msgid "Google Fonts"
msgstr "Google fontovi"

#: templates/admin/scan-fonts.php:74
msgid ""
"Control how Google Fonts are loaded. Self-host for faster load times, better"
" privacy and GDPR compliance."
msgstr ""
"Odredite kako se Google fontovi učitavaju. Samostalni hosting omogućuje brže"
" učitavanje, bolju privatnost i usklađenost s GDPR-om."

#: templates/admin/scan-fonts.php:78
msgid "Self-Host Google Fonts"
msgstr "Hostaj Google fontove lokalno"

#: templates/admin/scan-fonts.php:78
msgid ""
"Off: Fonts load from Google servers — may share visitor data with Google. "
"Local: Downloads and serves fonts from your own server for full GDPR "
"compliance. Bunny Fonts (Recommended): Free, privacy-first Google Fonts "
"alternative powered by bunny.net global CDN — lightning-fast delivery, zero "
"tracking, fully GDPR compliant."
msgstr ""
"Isključeno: fontovi se učitavaju s Google poslužitelja — to može dijeliti "
"podatke posjetitelja s Googleom. Lokalno: preuzima i poslužuje fontove s "
"vašeg vlastitog poslužitelja za potpunu usklađenost s GDPR-om. Bunny Fonts "
"(preporučeno): besplatna alternativa Google fontovima usmjerena na "
"privatnost, pokretana globalnim CDN-om bunny.net — munjevito brza isporuka, "
"bez praćenja, potpuno usklađena s GDPR-om."

#: templates/admin/scan-fonts.php:80
msgid "Local Fonts (GDPR)"
msgstr "Lokalni fontovi (GDPR)"

#: templates/admin/scan-fonts.php:81
msgid "Bunny Fonts (GDPR + CDN)"
msgstr "Bunny Fonts (GDPR + CDN)"

#: templates/admin/scan-fonts.php:84
msgid "Purge & Rescan Font Cache"
msgstr "Očisti i ponovno skeniraj predmemoriju fontova"

#: templates/admin/scan-fonts.php:84
msgid ""
"Clear the font cache and re-scan your homepage to detect newly added or "
"removed fonts."
msgstr ""
"Očistite predmemoriju fontova i ponovno skenirajte početnu stranicu kako "
"biste otkrili novo dodane ili uklonjene fontove."

#: templates/admin/scan-fonts.php:92
msgid "Google Fonts Scanner"
msgstr "Skener Google fontova"

#: templates/admin/scan-fonts.php:92
msgid "Scan any page on your site to detect which Google Fonts are loaded."
msgstr ""
"Skenirajte bilo koju stranicu na svojoj web-stranici kako biste otkrili koji"
" su Google fontovi učitani."

#: templates/admin/scan-fonts.php:96
msgid "https://yoursite.com/page-to-scan"
msgstr "https://yoursite.com/page-to-scan"

#: templates/admin/scan-fonts.php:99
msgid "Scan"
msgstr "Skeniraj"

#: templates/admin/scan-fonts.php:105
msgid "Google Fonts detected! See results below."
msgstr "Google fontovi su otkriveni! Pogledajte rezultate ispod."

#: templates/admin/scan-fonts.php:124
msgid "Detected Google Fonts"
msgstr "Otkriveni Google fontovi"

#: templates/admin/scan-fonts.php:125
msgid "Google Fonts found on your site. Remove any you no longer need."
msgstr ""
"Na vašoj su stranici pronađeni Google fontovi. Uklonite one koji vam više "
"nisu potrebni."

